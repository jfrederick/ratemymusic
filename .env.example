# Spotify application client ID (public; used for OAuth authorization code flow).
SPOTIFY_CLIENT_ID=40f98cc66e5b40e6a925dfa00e5bdbb1
# Anthropic API key, used by the chat assistant (PR9+).
ANTHROPIC_API_KEY=
# Anthropic model used by the chat assistant.
ANTHROPIC_MODEL=claude-opus-4-8
# Firecrawl API key, used to scrape RateYourMusic pages (PR3+).
FIRECRAWL_API_KEY=
# Daily spend cap (USD) enforced by the budget ledger.
BUDGET_DAILY=50
# Initial budget balance (USD) seeded on first run.
BUDGET_INITIAL=400
# HTTP port the @rmm/server API listens on.
PORT=8787
# RateYourMusic username whose collection is mined for taste data.
RYM_USERNAME=jimbof36
# Path to the SQLite database file. A relative value is always resolved against the repo root,
# regardless of the invoking process's cwd (e.g. `npm run discover -w @rmm/core`) -- see
# "Resetting the database" in docs/runbook.md.
RMM_DB_PATH=data/rmm.sqlite
# JSON weights for blending discovery methods (list/twin/genre/descriptor/new); must sum to 1.0.
BLEND_WEIGHTS={"list":0.30,"twin":0.25,"genre":0.20,"descriptor":0.15,"new":0.10}
# Set to 1 to run the daily sync -> discover -> push pipeline in-process on a node-cron schedule
# (07:00 local) inside @rmm/server. Leave unset/0 if you're using the launchd plist in ops/launchd/
# (or another external scheduler) to run `npm run push-daily` instead -- running both would push
# the daily playlist twice.
ENABLE_CRON=0
